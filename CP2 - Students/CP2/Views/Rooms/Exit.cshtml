@{
    ViewData["Title"] = "Exit Door (Room 10)";
    Layout = "_Layout";
}

@section Styles {
    <style>
        body {
            background-image: url("/imgs/exit.png");
            background-size: cover;
            background-position: center center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }
    </style>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 transparent-white spooky-white">
            <div class="card-body" style="background: transparent;">
                <h1 class="card-title text-center mb-4">@ViewData["Title"]</h1>

                <form asp-action="End" method="post" class="needs-validation">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="x" class="form-label">Por eso es que yo soy...</label>
                        <input type="text" id="x" name="x" class="form-control spooky-input-white" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 spooky-button-dr">Beat Me</button>
                </form>
            </div>
        </div>
    </div>
</div>
